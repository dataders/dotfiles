# Ghostty configuration
# https://ghostty.org/docs/config

desktop-notifications = true

# Theme (auto light/dark switching)
theme = light:GitHub Light Default,dark:GitHub Dark Default

# custom-shader = /Users/dataders/Developer/ghostty-shaders/retro-terminal.glsl
# custom-shader = /Users/dataders/Developer/ghostty-shaders/bloom.glsl
# custom-shader-animation = always

# Font (requires: brew install --cask font-jetbrains-mono-nerd-font)
font-family = JetBrainsMono Nerd Font
font-size = 14

# Shell integration (Ghostty's killer feature)
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = true
mouse-hide-while-typing = true
unfocused-split-opacity = 0.8

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# Quick terminal
quick-terminal-position = left

# Keybinds
keybind = cmd+shift+r=reload_config
keybind = cmd+w=close_tab
keybind = cmd+shift+h=new_split:down
keybind = cmd+shift+v=new_split:right
keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:down
keybind = cmd+k=goto_split:up
keybind = cmd+l=goto_split:right
keybind = cmd+shift+period=move_tab:1
keybind = cmd+shift+comma=move_tab:-1

# Performance
# vsync = true


