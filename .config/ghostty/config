# Ghostty configuration
# https://ghostty.org/docs/config

desktop-notifications = true

# Theme (auto light/dark switching)
# Catppuccin: warm cream light, deep mocha dark — overridden per-repo by cmux precmd hook
# theme = light:GitHub Light Default,dark:GitHub Dark Default

# ── Lofi Girl theme ───────────────────────────────────────────────────────────
# Three approaches — uncomment exactly ONE approach block at a time.
# Reload config: cmd+shift+r
#
# Approach A: GIF background + lightweight overlay (grain, warmth, vignette)
# Note: Ghostty GIF animation support is version-dependent; may show first frame only.
theme = lofi-dark
background-image = ~/.config/ghostty/assets/lofi-girl.gif
background-image-opacity = 0.15
custom-shader = ~/.config/ghostty/shaders/lofi-overlay.glsl
custom-shader-animation = always
#
# Approach B: static frame + full animated shader (rain, lamp bloom, grain)
# Swap in these three lines and comment out the three above.
# theme = lofi-dark
# background-image = ~/.config/ghostty/assets/lofi-girl.png
# background-image-opacity = 0.15
# custom-shader = ~/.config/ghostty/shaders/lofi-rain.glsl
# custom-shader-animation = always
#
# Approach C: no background-image — run `lofi-panel` in a right split instead
# (brew install chafa  required)
# theme = lofi-dark
# custom-shader = ~/.config/ghostty/shaders/lofi-overlay.glsl
# custom-shader-animation = always
# ─────────────────────────────────────────────────────────────────────────────

# previous shaders (kept for reference)
# custom-shader = ~/.config/ghostty/shaders/vignette.glsl
# custom-shader = ~/.config/ghostty/shaders/tft-subtle.glsl
# custom-shader = ~/.config/ghostty/shaders/starfield-subtle.glsl

# Font (requires: brew install --cask font-jetbrains-mono-nerd-font)
font-family = JetBrainsMono Nerd Font
font-size = 14
font-style = "Light"

# Shell integration (Ghostty's killer feature)
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = true
window-show-tab-bar = never
confirm-close-surface = false
mouse-hide-while-typing = true
unfocused-split-opacity = 0.70
split-divider-color = 45475a
split-inherit-working-directory = true
tab-inherit-working-directory = true
window-inherit-working-directory = true
window-inherit-font-size = true

# Agent sessions produce long traces; keep enough context without endless RAM use.
scrollback-limit = 50000

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# macOS
macos-option-as-alt = true

# Quick terminal
quick-terminal-position = left

# Keybinds
keybind = cmd+shift+r=reload_config
keybind = cmd+w=close_tab
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
keybind = cmd+ctrl+left=resize_split:left,20
keybind = cmd+ctrl+right=resize_split:right,20
keybind = cmd+ctrl+up=resize_split:up,10
keybind = cmd+ctrl+down=resize_split:down,10
keybind = alt+left=esc:b
keybind = alt+right=esc:f
keybind = alt+backspace=text:\x17

# Performance
# vsync = true

