**/.claude/settings.local.json

# direnv per-repo hooks. These call `source_dotfiles_env <name>` to load
# repo-scoped secrets from ~/Developer/dotfiles_env/projects/*.envrc, so the
# hook itself is non-secret but should not be committed to OSS repos.
# Personal repos that DO want to commit it: add `!.envrc` to the repo's local
# .gitignore, or `git add -f .envrc`.
.envrc

# Serena MCP per-repo dirs. The real project.yml + memories/ live in
# dotfiles/serena/projects/<repo>/ and are symlinked back in (see serena/README.md).
# cache/ is regenerable. dotfiles' own .serena/* stays tracked (already committed).
.serena/
