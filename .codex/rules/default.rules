# Shared Codex exec policy.
#
# Keep this file small and durable:
# - allow stable tool prefixes you trust across projects
# - forbid obviously dangerous prefixes
# - leave one-off long shell scripts to interactive approval

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Do not escalate through sudo from Codex.",
)

prefix_rule(
    pattern = ["doas"],
    decision = "forbidden",
    justification = "Do not escalate through doas from Codex.",
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Destructive recursive deletes must be approved explicitly.",
)

prefix_rule(
    pattern = ["rm", "-fr"],
    decision = "forbidden",
    justification = "Destructive recursive deletes must be approved explicitly.",
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Avoid destructive git resets from auto-approved rules.",
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Do not auto-approve force pushes.",
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Do not auto-approve force pushes.",
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Do not auto-approve force pushes.",
)

prefix_rule(
    pattern = ["git", "push", "--delete"],
    decision = "forbidden",
    justification = "Do not auto-approve branch deletion pushes.",
)

prefix_rule(
    pattern = ["git", "push", "--mirror"],
    decision = "forbidden",
    justification = "Do not auto-approve mirror pushes.",
)

prefix_rule(
    pattern = ["git", "push", "--all"],
    decision = "forbidden",
    justification = "Do not auto-approve bulk push operations.",
)

prefix_rule(
    pattern = [["pip", "pip3"]],
    decision = "forbidden",
    justification = "Use `uv` instead of bare pip.",
)

prefix_rule(
    pattern = ["open"],
    decision = "allow",
    justification = "Opening URLs and local files is routine.",
    match = [
        "open https://github.com/openai/codex",
    ],
)

prefix_rule(
    pattern = [["uv", "uvx"]],
    decision = "allow",
    justification = "Preferred Python tooling in this environment, including uv run.",
    match = [
        "uv run python3 -m http.server",
        "uv add ruff",
        "uv sync",
        "uv run python -m compileall .",
        "uvx ruff check",
    ],
)

prefix_rule(
    pattern = [
        [
            "dbt",
            "dbtf",
            "dbtd",
            "dbtr",
            "dbt-core",
            "/Users/dataders/.local/bin/dbt",
            "/Users/dataders/Developer/fs/target/release/dbt",
        ],
    ],
    decision = "allow",
    justification = "Primary trusted dbt tooling for this machine.",
    match = [
        "dbt debug",
        "dbtf --version",
        "/Users/dataders/.local/bin/dbt build",
    ],
)

prefix_rule(
    pattern = [
        "git",
        [
            "status",
            "log",
            "diff",
            "show",
            "describe",
            "tag",
            "blame",
            "branch",
            "checkout",
            "switch",
            "fetch",
            "pull",
            "add",
            "commit",
            "stash",
            "merge",
            "rebase",
            "remote",
            "rev-parse",
            "ls-files",
            "ls-tree",
            "ls-remote",
            "cat-file",
            "restore",
            "revert",
            "cherry-pick",
            "worktree",
        ],
    ],
    decision = "allow",
    justification = "Routine git workflow commands are trusted.",
    match = [
        "git status",
        "git add README.md",
        "git commit --no-verify",
        "git fetch origin",
    ],
    not_match = [
        "git push origin",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "allow",
    justification = "Allow normal pushes without force.",
    match = [
        "git push origin current-branch",
        "git push -u origin current-branch",
    ],
)

prefix_rule(
    pattern = ["gh", "api"],
    decision = "allow",
    justification = "Routine GitHub API inspection is trusted.",
    match = [
        "gh api repos/openai/codex",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "list", "diff", "checks", "status"]],
    decision = "allow",
    justification = "Routine GitHub PR inspection is trusted.",
    match = [
        "gh pr view 123",
        "gh pr checks 123",
    ],
)

prefix_rule(
    pattern = ["gh", ["issue", "repo"], ["view", "list"]],
    decision = "allow",
    justification = "Routine GitHub inspection is trusted.",
    match = [
        "gh issue list",
        "gh repo view openai/codex",
    ],
)

prefix_rule(
    pattern = ["gh", "run", ["list", "view", "watch"]],
    decision = "allow",
    justification = "Routine GitHub Actions inspection is trusted.",
    match = [
        "gh run list",
        "gh run view 123 --log",
        "gh run watch 123",
    ],
)

prefix_rule(
    pattern = ["gh", "workflow", "run"],
    decision = "allow",
    justification = "Triggering trusted GitHub workflows is routine.",
    match = [
        "gh workflow run ci.yml",
    ],
)

prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
    justification = "Checking GitHub CLI auth state is trusted.",
    match = [
        "gh auth status",
    ],
)

prefix_rule(
    pattern = ["launchctl", "getenv"],
    decision = "allow",
    justification = "Reading a launchd environment variable is trusted.",
    match = [
        "launchctl getenv PATH",
    ],
)

prefix_rule(
    pattern = ["git", "config", "--get"],
    decision = "allow",
    justification = "Reading a git config value is trusted.",
    match = [
        "git config --get user.name",
    ],
)

prefix_rule(
    pattern = ["git", "config", "--global", "--get"],
    decision = "allow",
    justification = "Reading a global git config value is trusted.",
    match = [
        "git config --global --get user.email",
    ],
)

prefix_rule(
    pattern = ["node", "--version"],
    decision = "allow",
    justification = "Checking Node.js version is trusted.",
    match = [
        "node --version",
    ],
)

prefix_rule(
    pattern = ["npm", "--version"],
    decision = "allow",
    justification = "Checking npm version is trusted.",
    match = [
        "npm --version",
    ],
)

prefix_rule(
    pattern = ["readlink"],
    decision = "allow",
    justification = "Resolving symlink targets is trusted.",
    match = [
        "readlink ~/.codex/config.toml",
    ],
)

prefix_rule(
    pattern = ["rtk"],
    decision = "allow",
    justification = "Allow trusted RTK-prefixed commands across tools.",
    match = [
        "rtk git status",
        "rtk cargo xtask test",
        "rtk npm run build",
    ],
)

prefix_rule(
    pattern = ["wt", ["list", "switch", "merge"]],
    decision = "allow",
    justification = "Routine Worktrunk operations are trusted.",
    match = [
        "wt list",
        "wt switch feature-branch",
        "wt merge main",
    ],
)

prefix_rule(
    pattern = ["cargo", "xtask"],
    decision = "allow",
    justification = "Trusted project automation entrypoint.",
    match = [
        "cargo xtask check",
        "cargo xtask test",
    ],
)

prefix_rule(
    pattern = ["sh", "links.sh"],
    decision = "allow",
    justification = "Refreshing local dotfile symlinks is routine here.",
    match = [
        "sh links.sh",
    ],
)

prefix_rule(
    pattern = ["sort", "-u"],
    decision = "allow",
    justification = "Simple text deduplication is trusted.",
    match = [
        "sort -u file.txt",
    ],
)
prefix_rule(pattern=["uv", "run", "python3", "-m", "unittest"], decision="allow")
prefix_rule(pattern=["uv", "run", "prefab", "export"], decision="allow")
prefix_rule(pattern=["uv", "run", "python3", "-m", "http.server", "8081"], decision="allow")
prefix_rule(pattern=["open", "http://127.0.0.1:8081/"], decision="allow")
prefix_rule(pattern=["open", "http://127.0.0.1:8081/prefab/app_windows_2000.html"], decision="allow")
prefix_rule(pattern=["git", "worktree", "remove", "/Users/dataders/Developer/fs.zachruben-model-docs-panel"], decision="allow")
