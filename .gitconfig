
[user]
	name = Anders Swanson
	email = anders.swanson@dbtlabs.com
	signingkey = /Users/dataders/.ssh/id_ed25519.pub
[core]
	editor = "cursor --wait"
	symlink = true
	symlinks = true
	pager = delta
	excludesfile = /Users/dataders/.gitignore_global
[pull]
	ff = only
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[http]
	postBuffer = 524288000
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = /Users/dataders/.ssh/allowed_signers
[diff]
    algorithm = histogram
	renameLimit = 3000
[rerere]
    enabled = true
    autoUpdate = true
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[include]
	path = ~/Developer/dotfiles_env/gitconfig.local
