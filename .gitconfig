
[user]
	name = Anders Swanson
	email = anders.swanson@dbtlabs.com
	signingkey = /Users/dataders/.ssh/id_ed25519.pub
[core]
	editor = "cursor --wait"
	symlink = true
	symlinks = true
	pager = cat
	excludesfile = /Users/dataders/.gitignore_global
[pull]
	rebase = false
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[http]
	postBuffer = 524288000
[gpg]
	format = ssh
[diff]
    algorithm = histogram
	renameLimit = 3000
[rerere]
    enabled = true
    autoUpdate = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
