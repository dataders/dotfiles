#!/usr/bin/env bash
# Capture Moonlander HID console output as clean 8-column CSV.
#   moonlander-keylog            # run qmk console, append to dated log
#   moonlander-keylog --filter   # read stdin, emit clean CSV (for tests)
set -euo pipefail

# Homebrew's qmk lives in /opt/homebrew/bin; ensure it's reachable under launchd.
case ":$PATH:" in *":/opt/homebrew/bin:"*) ;; *) PATH="/opt/homebrew/bin:$PATH";; esac
export PATH
# qmk console is Python; when its stdout is a pipe (not a tty) it block-buffers,
# so a slow trickle of keypresses never reaches the file. Force unbuffered I/O.
export PYTHONUNBUFFERED=1

LOGDIR="$HOME/.local/share/moonlander-keylog"
# 8 fields: keycode,row,col,layer,pressed(0/1),mods,oneshotmods,tapcount
PATTERN='0x[0-9A-Fa-f]{4},[0-9]+,[0-9]+,[0-9]+,[01],0x[0-9A-Fa-f]{2},0x[0-9A-Fa-f]{2},[0-9]+'

# --line-buffered so grep flushes each match immediately instead of in ~4KB blocks.
filter() { grep --line-buffered -oE "$PATTERN"; }

if [ "${1:-}" = "--filter" ]; then
  filter
  exit 0
fi

# No `-d VID:PID` pin: only the Moonlander runs our 8-field hook, and the strict
# PATTERN above discards any other QMK console output, so capturing all consoles
# is both simpler and more robust than qmk's ambiguous <pid>:<vid> device flag.
mkdir -p "$LOGDIR"
exec qmk console 2>/dev/null \
  | filter \
  | while IFS= read -r line; do
      printf '%s\n' "$line" >> "$LOGDIR/keylog-$(date +%Y%m%d).csv"
    done
